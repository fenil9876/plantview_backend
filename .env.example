# --- Database (Postgres) ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=changeme
DB_NAME=plantview

# --- App ---
APP_ENV=development
DEBUG=true

# Comma-separated list of allowed CORS origins (the frontend URL)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Auth ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=720

# Initial admin, created by: python -m app.scripts.seed_admin
FIRST_ADMIN_EMAIL=admin@yourcompany.com
FIRST_ADMIN_PASSWORD=change-me
